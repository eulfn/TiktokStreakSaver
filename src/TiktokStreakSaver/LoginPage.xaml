<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TiktokStreakSaver.LoginPage"
             Title="Login to TikTok"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
    
    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="0">
            <VerticalStackLayout Spacing="6" Padding="20">
                <Label Text="Login to TikTok" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                <Label Text="Your session will be saved for background messaging. Only login via the official website." FontSize="14" TextColor="{StaticResource Gray500}" LineBreakMode="WordWrap"/>
            </VerticalStackLayout>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
        </VerticalStackLayout>
        
        <!-- WebView -->
        <WebView x:Name="TikTokWebView" Grid.Row="1" Navigated="OnWebViewNavigated"/>
        
        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.Row="1" IsVisible="True" BackgroundColor="{AppThemeBinding Light=#EEFFFFFF, Dark=#EE000000}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">
                <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" HeightRequest="48" WidthRequest="48"/>
                <Label Text="Loading web frame..." FontSize="14" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
        
        <!-- Footer Actions -->
        <VerticalStackLayout Grid.Row="2" Spacing="0">
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
            <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Padding="20">
                <Button Text="Back" Style="{StaticResource TextButton}" Clicked="OnBackClicked"/>
                <Button Grid.Column="1" Text="Refresh" BackgroundColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray200}}" TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" CornerRadius="8" HeightRequest="50" Clicked="OnRefreshClicked"/>
            </Grid>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
